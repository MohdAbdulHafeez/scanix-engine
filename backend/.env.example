# ==========================================================
# SCANIX AI — CORE
# ==========================================================

PROJECT=SCANIX AI

APP_NAME=SCANIX AI

VERSION=1.0.0

PROJECT_MODE=nutrition


ENV=development

DEBUG=true

LOG_LEVEL=INFO


HOST=0.0.0.0

PORT=8000


SECRET_KEY=

JWT_SECRET=

JWT_EXPIRE_MINUTES=60

REFRESH_TOKEN_EXPIRE_DAYS=30



# ==========================================================
# AI
# ==========================================================

GEMINI_API_KEY=

GROQ_API_KEY=

OPENROUTER_API_KEY=


AI_DEFAULT_PROVIDER=gemini

AI_FALLBACK_PROVIDER=groq

DEFAULT_MODEL=gemini-2.5-flash

AI_TIMEOUT_SECONDS=

AI_MAX_RETRIES=




# ==========================================================
# FOOD DATA
# ==========================================================

OPENFOODFACTS_URL=https://world.openfoodfacts.org

USDA_API_KEY=

SPOONACULAR_API_KEY=

APININJAS_API_KEY=



# ==========================================================
# FATSECRET
# ==========================================================

FATSECRET_CLIENT_ID=

FATSECRET_CONSUMER_KEY=

FATSECRET_CONSUMER_SECRET=


# ==========================================================
# RESEARCH
# ==========================================================

PUBMED_EMAIL=

CROSSREF_BASE_URL=https://api.crossref.org

CROSSREF_MAILTO=



# ==========================================================
# SAFETY
# ==========================================================

OPENFDA_URL=https://api.fda.gov

OPENFDA_ENABLED=true



# ==========================================================
# DATABASE
# ==========================================================

DATABASE_URL=

SUPABASE_URL=

SUPABASE_KEY=

SUPABASE_SERVICE_KEY=

DATABASE_POOL_SIZE=

DATABASE_MAX_OVERFLOW=

# ==========================================================
# OCR
# ==========================================================

OCR_PROVIDER=tesseract

TESSERACT_PATH=



# ==========================================================
# CACHE
# ==========================================================

REDIS_URL=redis://localhost:6379

CACHE_TTL=3600



# ==========================================================
# VECTOR SEARCH / RAG
# ==========================================================

ENABLE_RAG=false

VECTOR_DB=qdrant

VECTOR_COLLECTION=scanix_food


QDRANT_URL=

QDRANT_API_KEY=



# ==========================================================
# VOICE
# ==========================================================

VOICE_PROVIDER=edge

VOICE_MODE=normal



# ==========================================================
# SCAN
# ==========================================================

MAX_SCAN_IMAGES=4

MAX_UPLOAD_MB=10



# ==========================================================
# SCORE
# ==========================================================

DEFAULT_SCORE=70



# ==========================================================
# BACKGROUND JOBS
# ==========================================================

CELERY_BROKER_URL=redis://localhost:6379

CELERY_RESULT_BACKEND=redis://localhost:6379



# ==========================================================
# OBSERVABILITY
# ==========================================================

SENTRY_DSN=

POSTHOG_API_KEY=



# ==========================================================
# DEPLOYMENT
# ==========================================================

FRONTEND_URL=http://localhost:3000

BACKEND_URL=http://localhost:8000